{
  "name": "meli-seller-dashboard",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "install:all": "npm install",
    "dev": "concurrently \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "dev:api": "npm run dev -w backend",
    "dev:web": "npm run dev -w frontend",
    "start:api": "npm run start -w backend",
    "start:web": "npm run preview -w frontend",
    "seed": "npm run seed -w backend",
    "test": "npm test -w backend && npm test -w frontend",
    "test:e2e": "npm run seed && playwright test",
    "build": "npm run build -w backend && npm run build -w frontend",
    "start": "concurrently \"npm run start:api\" \"npm run start:web\""
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "concurrently": "latest",
    "typescript": "latest"
  }
}
